# Frontend Environment Variables (VITE_*)
VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key
VITE_QUALTRICS_SURVEY_URL=your_qualtrics_survey_url
# Optional: Question ID for Codice (e.g. QID12) so the app adds Q_PopulateResponse to pre-fill that question
# VITE_QUALTRICS_CODICE_QID=QID12

# Edge Functions Secrets (set via Supabase CLI)
# These are used when running: supabase secrets set --env-file .env
JWT_SECRET=your_random_secret_key_here

# Resend API key (required for Phase 5 - email reminders)
# Get your API key from https://resend.com/api-keys
# Free tier: 100 emails/day
RESEND_API_KEY=re_your_resend_api_key

# Resend from email (optional - defaults to noreply@meditation-training.app)
# Use a verified domain for better deliverability: "Name <email@yourdomain.com>"
# RESEND_FROM_EMAIL=Meditation Training <noreply@yourdomain.com>

# Frontend URL (required for Phase 5 - used in reminder emails)
# This should be the public URL where your dashboard is hosted
# e.g., https://your-domain.com or https://your-app.vercel.app
FRONTEND_URL=https://your-domain.com

# Optional: App timezone (defaults to America/New_York)
# Used to determine "today" for daily logs and reminders
# APP_TIMEZONE=America/New_York
