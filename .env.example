# Frontend Environment Variables (VITE_*)
VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key
VITE_QUALTRICS_SURVEY_URL=your_qualtrics_survey_url
# Optional: Question ID for Codice (e.g. QID12) so the app adds Q_PopulateResponse to pre-fill that question
# VITE_QUALTRICS_CODICE_QID=QID12

# Edge Functions Secrets (set via Supabase CLI)
# These are used when running: supabase secrets set --env-file .env
JWT_SECRET=your_random_secret_key_here

# Optional: Resend API key (for Phase 5)
# RESEND_API_KEY=re_your_resend_api_key
